# ── ehr-medaea-website — Environment Variables ────────────────────────────────
# Copy to .env before running dev server or building:
#   cp .env.example .env
#
# These are BUILD-TIME variables baked into the JS bundle by Vite.
# Changing them requires a full rebuild (npm run build or docker build).
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Medaea EHR app (React frontend).
# The "Login" and "Get Started" buttons link here.
# Local dev:         http://localhost:5000
# Production EHR:    https://app.medaea.ai
VITE_APP_URL=http://localhost:5000

# App name (displayed in metadata)
VITE_APP_NAME=Medaea EHR
